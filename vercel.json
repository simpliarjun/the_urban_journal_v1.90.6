{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/admin", "destination": "/public/admin/index.html" },
    { "source": "/admin/", "destination": "/public/admin/index.html" },
    { "source": "/(.*)", "destination": "/public/$1" }
  ],
  "functions": {
    "api/*.py": {
      "excludeFiles": "public/**"
    }
  }
}