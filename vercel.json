{
  "version": 2,
  "builds": [
    {
      "src": "api/admin.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": "api/**"
      }
    },
    {
      "src": "api/admin_approve.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": "api/**"
      }
    },
    {
      "src": "api/admin_reject.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": "api/**"
      }
    },
    {
      "src": "api/submit_comment.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": "api/**"
      }
    },
    {
      "src": "api/verify_comment.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": "api/**"
      }
    },
    {
      "src": "api/admin_create_post.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": "api/**"
      }
    },
    {
      "src": "public/admin/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/admin_create_post",
      "dest": "/api/admin_create_post.py"
    },
    {
      "src": "/api/admin_approve",
      "dest": "/api/admin_approve.py"
    },
    {
      "src": "/api/admin_reject",
      "dest": "/api/admin_reject.py"
    },
    {
      "src": "/api/submit_comment",
      "dest": "/api/submit_comment.py"
    },
    {
      "src": "/api/verify_comment",
      "dest": "/api/verify_comment.py"
    },
    {
      "src": "/api/admin",
      "dest": "/api/admin.py"
    },
    {
      "src": "/$",
      "dest": "/public/admin/index.html"
    },
    {
      "src": "/admin",
      "dest": "/public/admin/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/admin/index.html"
    }
  ]
}
