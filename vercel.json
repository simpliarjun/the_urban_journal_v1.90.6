{
  "version": 2,
  "outputDirectory": "public",
  "buildCommand": "python3 build_site.py",
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/*.py": {
      "excludeFiles": "public/**"
    }
  },
  "routes": [
    { "src": "/api/submit_comment", "dest": "/api/submit_comment.py" },
    { "src": "/api/verify_comment", "dest": "/api/verify_comment.py" }
  ]
}
